# Core runtime
APP_ENV=production
LOG_LEVEL=INFO

# Gateway / Bridge
GRPC_TARGET=gateway:50051
BRIDGE_API_PORT=8080
CORS_ALLOW_ORIGINS=*
VITE_API_BASE_URL=http://localhost:8080

# PostgreSQL (REQUIRED for docker-compose.prod.yml)
POSTGRES_DB=neural_trader
POSTGRES_USER=trader
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD

# Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN

# Exchange API keys (set these for live/testnet trading)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSPHRASE=

# Redis (optional — leave empty for no auth)
REDIS_PASSWORD=

# Dashboard API key (optional)
# DASHBOARD_API_KEY=

# Telegram alerts (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Discord alerts (optional)
# DISCORD_WEBHOOK_URL=

# Live trading safety gate
# LIVE_TRADING_CONFIRMED=true

# ClickHouse (if using ClickHouse instead of PostgreSQL)
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=clickhouse_admin
# CLICKHOUSE_DB=neural_trader
